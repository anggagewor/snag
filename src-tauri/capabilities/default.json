{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        {
          "url": "http://**"
        },
        {
          "url": "https://**"
        }
      ]
    },
    {
      "identifier": "http:allow-fetch-send",
      "allow": [
        {
          "url": "http://**"
        },
        {
          "url": "https://**"
        }
      ]
    },
    "fs:read-all",
    "fs:write-all",
    "fs:create-app-specific-dirs",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPDATA"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$APPLOCALDATA"
        },
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPCONFIG"
        },
        {
          "path": "$APPCONFIG/**"
        },
        {
          "path": "$APPCACHE"
        },
        {
          "path": "$APPCACHE/**"
        },
        {
          "path": "$APPLOG"
        },
        {
          "path": "$APPLOG/**"
        },
        {
          "path": "$HOME"
        },
        {
          "path": "$HOME/**"
        },
        {
          "path": "$DOCUMENT"
        },
        {
          "path": "$DOCUMENT/**"
        },
        {
          "path": "$DOWNLOAD"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$DESKTOP"
        },
        {
          "path": "$DESKTOP/**"
        },
        {
          "path": "$RESOURCE/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        {
          "path": "$APPDATA"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$APPLOCALDATA"
        },
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPCONFIG"
        },
        {
          "path": "$APPCONFIG/**"
        },
        {
          "path": "$APPCACHE"
        },
        {
          "path": "$APPCACHE/**"
        },
        {
          "path": "$APPLOG"
        },
        {
          "path": "$APPLOG/**"
        },
        {
          "path": "$HOME"
        },
        {
          "path": "$HOME/**"
        },
        {
          "path": "$DOCUMENT"
        },
        {
          "path": "$DOCUMENT/**"
        },
        {
          "path": "$DOWNLOAD"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$DESKTOP"
        },
        {
          "path": "$DESKTOP/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        {
          "path": "$APPDATA"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$APPLOCALDATA"
        },
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPCONFIG"
        },
        {
          "path": "$APPCONFIG/**"
        },
        {
          "path": "$APPCACHE"
        },
        {
          "path": "$APPCACHE/**"
        },
        {
          "path": "$APPLOG"
        },
        {
          "path": "$APPLOG/**"
        },
        {
          "path": "$HOME"
        },
        {
          "path": "$HOME/**"
        },
        {
          "path": "$DOCUMENT"
        },
        {
          "path": "$DOCUMENT/**"
        },
        {
          "path": "$DOWNLOAD"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$DESKTOP"
        },
        {
          "path": "$DESKTOP/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        {
          "path": "$APPDATA"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$APPLOCALDATA"
        },
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPCONFIG"
        },
        {
          "path": "$APPCONFIG/**"
        },
        {
          "path": "$APPCACHE"
        },
        {
          "path": "$APPCACHE/**"
        },
        {
          "path": "$APPLOG"
        },
        {
          "path": "$APPLOG/**"
        },
        {
          "path": "$HOME"
        },
        {
          "path": "$HOME/**"
        },
        {
          "path": "$DOCUMENT"
        },
        {
          "path": "$DOCUMENT/**"
        },
        {
          "path": "$DOWNLOAD"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$DESKTOP"
        },
        {
          "path": "$DESKTOP/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        {
          "path": "$APPDATA"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$APPLOCALDATA"
        },
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPCONFIG"
        },
        {
          "path": "$APPCONFIG/**"
        },
        {
          "path": "$APPCACHE"
        },
        {
          "path": "$APPCACHE/**"
        },
        {
          "path": "$APPLOG"
        },
        {
          "path": "$APPLOG/**"
        },
        {
          "path": "$HOME"
        },
        {
          "path": "$HOME/**"
        },
        {
          "path": "$DOCUMENT"
        },
        {
          "path": "$DOCUMENT/**"
        },
        {
          "path": "$DOWNLOAD"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$DESKTOP"
        },
        {
          "path": "$DESKTOP/**"
        }
      ]
    },
    "dialog:default"
  ]
}
